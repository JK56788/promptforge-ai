# --- PromptForge environment variables ---
#
# 1. Get a FREE Gemini API key (no credit card) at: https://aistudio.google.com/apikey
# 2. Copy this file and rename the copy to ".env"
# 3. Paste your key after the = sign below (no quotes, no spaces)
# 4. Restart the dev server (npm run dev) so the key is picked up
#
VITE_GEMINI_API_KEY=

# Optional: override the model. Default is gemini-2.5-flash (free tier, vision).
# VITE_GEMINI_MODEL=gemini-2.5-flash
